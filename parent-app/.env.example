# ── Asterisk WebSocket (WS) SIP Server ────────────────────────────────────────
# The WebSocket URL for your Asterisk server's WSS/WS transport.
# For local Asterisk: ws://localhost:8088/ws
# For production:     wss://your-server.com:8089/ws
NEXT_PUBLIC_ASTERISK_WS_URL=ws://localhost:8088/ws

# ── Parent SIP Account (this app's credentials) ───────────────────────────────
# This app registers as "parent" extension on Asterisk.
NEXT_PUBLIC_SIP_USERNAME=parent
NEXT_PUBLIC_SIP_PASSWORD=parentpass123
NEXT_PUBLIC_SIP_DOMAIN=localhost

# ── Monto Box SIP Extension ───────────────────────────────────────────────────
# The SIP extension the Monto AI box is registered as.
NEXT_PUBLIC_MONTO_BOX_EXTENSION=monto

# ── Monto AI Backend ──────────────────────────────────────────────────────────
# Used to notify the backend to initiate a call from the box side.
NEXT_PUBLIC_MONTO_API_URL=http://localhost:8000
