# Asterisk WebSocket URL — browser connects directly
# Replace with your server IP
NEXT_PUBLIC_ASTERISK_WS_URL=ws://192.168.1.100:8088/ws

# SIP credentials — must match asterisk/sip.conf
NEXT_PUBLIC_SIP_USERNAME=parent
NEXT_PUBLIC_SIP_PASSWORD=parentpass123
NEXT_PUBLIC_SIP_DOMAIN=192.168.1.100

# Monto box SIP extension (what the parent calls)
NEXT_PUBLIC_MONTO_BOX_EXTENSION=monto

# Monto AI backend (for health checks + call control)
NEXT_PUBLIC_MONTO_API_URL=http://192.168.1.100:8000
