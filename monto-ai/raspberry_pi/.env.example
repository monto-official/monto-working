# GPU machine backend (primary)
BACKEND_URL=http://192.168.1.100:8000

# Fallback backend — used if GPU offline for 1 minute
FALLBACK_BACKEND_URL=

# Session ID — unique per Pi device
SESSION_ID=pi-monto

# Recording duration in seconds
RECORD_SECONDS=5

# Fullscreen display
FULLSCREEN=true

# GPIO button pin number (BCM numbering)
# Set to 0 to disable GPIO (use ENTER/SPACE key instead)
# Example: GPIO_BUTTON_PIN=18  (connect button between GPIO18 and GND)
GPIO_BUTTON_PIN=0

# Wake word sensitivity (0.0 to 1.0) — lower = more sensitive but more false triggers
WAKE_THRESHOLD=0.5

# Path to custom "Hey Monto" wake word model (.tflite file)
# Leave empty to use built-in wake word
WAKE_MODEL_PATH=

# Built-in wake word to use (when WAKE_MODEL_PATH is empty)
# Options: alexa | hey_jarvis | hey_mycroft | timer | weather
WAKE_WORD=hey_jarvis

# ── SIP / Asterisk (for calling the parent app) ───────────────────────────────
# IP of the GPU server running Asterisk (same as BACKEND_URL host)
ASTERISK_HOST=192.168.1.100

# SIP credentials for the Monto box extension — must match asterisk/sip.conf
SIP_USERNAME=monto
SIP_PASSWORD=montopass123
SIP_DOMAIN=192.168.1.100

# Parent SIP extension name (must match asterisk/sip.conf)
PARENT_EXTENSION=parent
