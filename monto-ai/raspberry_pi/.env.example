# IP of the machine running the Monto backend
BACKEND_URL=http://192.168.1.101:8000

# Free key from https://picovoice.ai/
PORCUPINE_KEY=your_picovoice_access_key_here

# How many seconds to record after wake word
RECORD_SECONDS=5

# Set to true if Pi is connected to a full screen display (TV/monitor)
FULLSCREEN=true

# Unique ID for this Pi device — keeps memory separate if you have multiple devices
# Change this to the child's name e.g. SESSION_ID=aarav or SESSION_ID=sita
SESSION_ID=pi-device-1
