# IP of the machine running the Monto backend (GPU machine via Tailscale)
BACKEND_URL=http://100.76.66.40:8000

# Fallback backend — used if GPU is offline for 1 minute
# Set this to your laptop's Tailscale IP or any other backend
FALLBACK_BACKEND_URL=http://100.122.50.13:8000

# How many seconds to record after wake word
RECORD_SECONDS=5

# Set to true for full screen display
FULLSCREEN=true

# Unique ID for this Pi device — keeps memory separate per device
SESSION_ID=pi-device-1

# Wake word sensitivity (0.0 to 1.0) — lower = more sensitive but more false triggers
WAKE_THRESHOLD=0.5

# Path to custom "Hey Monto" wake word model (.tflite file)
# Leave empty to use built-in wake word
WAKE_MODEL_PATH=

# Built-in wake word to use (when WAKE_MODEL_PATH is empty)
# Options: alexa | hey_jarvis | hey_mycroft | timer | weather
# "alexa" works best — just say "Alexa" to trigger
WAKE_WORD=hey_jarvis
