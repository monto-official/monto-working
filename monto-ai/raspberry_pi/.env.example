# GPU machine backend (primary)
BACKEND_URL=http://100.76.66.40:8000

# Fallback backend — used if GPU offline for 1 minute
FALLBACK_BACKEND_URL=http://100.122.50.13:8000

# Session ID — unique per device
SESSION_ID=pi-monto

# Recording duration in seconds
RECORD_SECONDS=5

# Fullscreen display
FULLSCREEN=true

# GPIO button pin number (BCM numbering)
# Set to 0 to disable GPIO (use ENTER key instead)
# Example: GPIO_BUTTON_PIN=18  (connect button between GPIO18 and GND)
GPIO_BUTTON_PIN=0
