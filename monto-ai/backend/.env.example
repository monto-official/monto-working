# ═══════════════════════════════════════════════════════════════
#  Monto AI — Backend Environment
#
#  Two modes:
#    USE_LOCAL_GPU=false  → Groq + ElevenLabs (easy testing)
#    USE_LOCAL_GPU=true   → GPU server: Whisper + Ollama + Piper
# ═══════════════════════════════════════════════════════════════

# ── MODE ──────────────────────────────────────────────────────
USE_LOCAL_GPU=false

# ── GROQ CLOUD (used when USE_LOCAL_GPU=false) ────────────────
GROQ_API_KEY=your_groq_api_key
# Model for LLM — llama-3.3-70b-versatile supports JSON mode reliably
# Do NOT use qwen/qwen3-32b here — it returns 400 with response_format
GROQ_LLM_MODEL=llama-3.3-70b-versatile

# Whisper language hint — reduces hallucination on near-silence
# Use "en" for English, "ne" for Nepali, leave empty for auto-detect
WHISPER_LANGUAGE=en_here

# ── ELEVENLABS (used when USE_LOCAL_GPU=false) ────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── GPU SERVER (used when USE_LOCAL_GPU=true) ─────────────────
# IP of your GPU machine — run gpu_server/start_gpu_server.sh there

GPU_SERVER_API_KEY=monto-secret-2024

GPU_WHISPER_URL=http://192.168.1.100:5001    # Whisper STT server
GPU_OLLAMA_URL=http://192.168.1.100:11434    # Ollama LLM server
GPU_PIPER_URL=http://192.168.1.100:5002      # Piper TTS server (English)
GPU_NEPALI_TTS_URL=http://192.168.1.100:5003 # gTTS Nepali TTS server

LOCAL_LLM_MODEL=qwen3:8b                     # must match what Ollama has pulled
PIPER_DEFAULT_VOICE=en_US-amy-medium         # must be downloaded on GPU machine

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── MEMORY DB ─────────────────────────────────────────────────
MEMORY_DB_PATH=monto_memory.db

# ── ASTERISK / VOIP ────────────────────────────────────────────────────────
# Asterisk server host (can be same machine as backend)
ASTERISK_HOST=127.0.0.1

# AMI (Asterisk Manager Interface) port — default 5038
ASTERISK_AMI_PORT=5038

# AMI credentials — must match manager.conf on Asterisk
ASTERISK_AMI_USER=montoami
ASTERISK_AMI_SECRET=montoamisecret

# SIP extension names — must match sip.conf
PARENT_EXTENSION=parent
MONTO_EXTENSION=monto
ASTERISK_CONTEXT=monto-calls

# Update ALLOWED_ORIGINS to also include parent app (port 3001)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
