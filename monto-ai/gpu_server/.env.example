# ── GPU Server Configuration ──────────────────────────────────────────────────
# Must match GPU_SERVER_API_KEY in backend/.env
GPU_SERVER_API_KEY=monto-secret-2024

# ── Whisper STT (port 5001) ────────────────────────────────────────────────────
WHISPER_MODEL=large-v3       # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cuda          # cuda | cpu
WHISPER_COMPUTE=float16      # float16 | int8 (int8 = less VRAM, slightly slower)
WHISPER_PORT=5001

# Language hint — reduces hallucination on near-silence
# Use "en" for English, "ne" for Nepali, leave blank for auto-detect
WHISPER_LANGUAGE=

# ── Piper TTS (port 5002) ─────────────────────────────────────────────────────
PIPER_DEFAULT_VOICE=en_US-amy-medium   # must be downloaded in ./voices/
PIPER_VOICES_DIR=./voices
PIPER_BIN=piper                        # path to piper binary if not in PATH
PIPER_PORT=5002

# ── Nepali TTS (port 5003) ─────────────────────────────────────────────────────
# Uses Microsoft Edge TTS (free, no API key needed)
NEPALI_VOICE=ne-NP-HemkalaNeural       # Female — best for kids
# NEPALI_VOICE=ne-NP-SagarNeural       # Male alternative
NEPALI_TTS_PORT=5003

# ── Ollama LLM (port 11434) ────────────────────────────────────────────────────
# Ollama manages its own config — just make sure the model is pulled:
#   ollama pull qwen3:8b
LOCAL_LLM_MODEL=qwen3:8b
