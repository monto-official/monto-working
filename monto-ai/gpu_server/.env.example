# ── SECURITY ──────────────────────────────────────────────────
# Must match GPU_SERVER_API_KEY in backend/.env
GPU_SERVER_API_KEY=monto-secret-2024

# ── WHISPER STT ───────────────────────────────────────────────
# Model: tiny | base | small | medium | large-v3
# VRAM:  ~1GB  | ~1GB | ~2GB  | ~5GB   | ~10GB
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE=float16
WHISPER_PORT=5001

# ── PIPER TTS ─────────────────────────────────────────────────
# Voice name — must be downloaded first (setup does this automatically)
# Child-friendly voices: en_US-amy-medium, en_US-lessac-medium
PIPER_DEFAULT_VOICE=en_US-amy-medium
PIPER_VOICES_DIR=./voices
PIPER_PORT=5002

# ── OLLAMA LLM ────────────────────────────────────────────────
# Model: qwen3:8b needs ~6GB VRAM
LOCAL_LLM_MODEL=qwen3:8b
