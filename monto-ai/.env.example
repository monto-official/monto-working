# ══════════════════════════════════════════════════════════════════════════════
#  Monto AI — Master .env  (copy to .env and fill in your values)
#  Used by docker-compose.yml for ALL services.
# ══════════════════════════════════════════════════════════════════════════════

# ── Your GPU server's LAN IP (or public IP) ──────────────────────────────────
# Every service uses this so the browser knows how to reach Asterisk/backend.
SERVER_IP=192.168.1.100

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kathmandu

# ── AI Mode ───────────────────────────────────────────────────────────────────
# true  = use local GPU (Whisper + Ollama + Piper) — fully offline
# false = use Groq + ElevenLabs cloud APIs
USE_LOCAL_GPU=true

# ── Groq API (only needed when USE_LOCAL_GPU=false) ───────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_LLM_MODEL=llama-3.3-70b-versatile
WHISPER_LANGUAGE=en

# ── ElevenLabs TTS (only needed when USE_LOCAL_GPU=false) ─────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Local GPU server URLs (only needed when USE_LOCAL_GPU=true) ───────────────
# These point to services running on the SAME GPU machine.
GPU_SERVER_API_KEY=monto-secret-2024
GPU_WHISPER_URL=http://127.0.0.1:5001
GPU_OLLAMA_URL=http://127.0.0.1:11434
GPU_PIPER_URL=http://127.0.0.1:5002
LOCAL_LLM_MODEL=qwen3:8b
PIPER_DEFAULT_VOICE=en_US-amy-medium

# ── SIP / Asterisk ────────────────────────────────────────────────────────────
# These passwords MUST match what's in asterisk/sip.conf and asterisk/manager.conf.
# Change them before deploying!

PARENT_SIP_USERNAME=parent
PARENT_SIP_PASSWORD=parentpass123      # change this!

MONTO_SIP_USERNAME=monto
MONTO_SIP_PASSWORD=montopass123        # change this!  (Pi uses this)

# AMI credentials (backend → Asterisk)
ASTERISK_AMI_USER=montoami
ASTERISK_AMI_SECRET=montoamisecret     # change this!

# SIP extension routing config (usually no need to change)
PARENT_EXTENSION=parent
MONTO_EXTENSION=monto
ASTERISK_CONTEXT=monto-calls
